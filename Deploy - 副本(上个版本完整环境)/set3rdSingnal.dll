	<FunNum BussiNumber ="60"  Name="mapping设置显示方法">
		<Step orderIndex ="1"  orderStrName="设置显示方法">
			<Dev sdkIndex = "1"  DevType="7"  DevName="mapping"  FunNum="1"  FunName="设置显示方法">
				<parameter  paravalue="in1"  paratype="1"  paraIndex="700101"  paraCNname="显示模式">
				</parameter>
				<parameter  paravalue="700101"  paratype="5"  paraIndex="700102"  paraCNname="定长数组dwave[0]">
					<ValRange   selectIndex="0"   paraCNname="单波长强度">            <!--selectIndex = 根据700101 选择的值-->
						<ItemInfo numtype="0"  Value="0"    Text="value1"/>  <!--dwave[0]numtype=0 直接取值Value-->
					</ValRange>
					<ValRange   selectIndex="1"   paraCNname="积分高亮">
						<ItemInfo numtype="1"  Value="in1"    Text="value1"/>  <!--dwave[0]numtype=1 从协议里面取值-->
					</ValRange>
					<ValRange   selectIndex="2"   paraCNname="峰值波长">
						<ItemInfo numtype="0"  Value="0"    Text="value1"/>  <!--dwave[0]numtype=0 直接取值Value-->
					</ValRange>
					<ValRange   selectIndex="3"   paraCNname="半高宽">
						<ItemInfo numtype="1"  Value="in1"    Text="value1"/>  <!--dwave[0]numtype=1 从协议里面取值-->			
					</ValRange>
				</parameter>
				<parameter  paravalue="700101"  paratype="5"  paraIndex="700103"  paraCNname="定长数组dwave[1]">
					<ValRange   selectIndex="0"   paraCNname="单波长强度">            <!--selectIndex = 根据700101 选择的值-->
