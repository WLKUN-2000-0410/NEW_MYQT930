					</ValRange>
					<ValRange   selectIndex="1"   paraCNname="积分高亮">
						<ItemInfo numtype="1"  Value="in2"  Text="value2"/>    <!--dwave[1] numtype=1 从协议里面取值 -->
					</ValRange>
					<ValRange   selectIndex="2"   paraCNname="峰值波长">
						<ItemInfo numtype="0"  Value="0"  Text="value2"/>    <!--dwave[1] numtype=0 直接取值Value -->
					</ValRange>
					<ValRange   selectIndex="3"   paraCNname="半高宽">
						<ItemInfo numtype="1"  Value="in2"  Text="value2"/>    <!--dwave[1] numtype=1 从协议里面取值 -->				
					</ValRange>			
				</parameter>
			</Dev>
		</Step>
