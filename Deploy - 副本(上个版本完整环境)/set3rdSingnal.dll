<?xml version="1.0" encoding="UTF-8"?><!--SendFlag为0时,除执行失败,不发送消息,为1时,不管成功失败都发送-->
<root name="命令配置文件"> <!-- DoneIndex的值和DoneValue值  是否 匹配 时才执行，否则不执行   依据上一个sdk的执行结果-->
	<FunNum BussiNumber ="18"   Name="刷新获取仪器序列号">
