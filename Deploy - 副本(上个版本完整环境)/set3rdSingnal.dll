		<Step orderIndex ="1"  orderStrName="是否有狭缝">
			<Dev sdkIndex ="1"  DevType="3"  DevName="谱仪"  FunNum="5"  FunName="是否有狭缝">
				<parameter  paravalue=""  paratype="4"  paraIndex="300501"  paraCNname="索引">
					<ValRange   value="0"   paraCNname="侧入">     			   <!--都匹配了，取value值，赋300501值-->
						<ItemInfo ItemKey="300301" ItemValue="1"  Text="侧"/>  <!--ItemKey去匹配值，然后看是否和ItemValue相等-->
						<ItemInfo ItemKey="300201" ItemValue="1"  Text="入"/>  <!--ItemKey去匹配值，然后看是否和ItemValue相等-->
					</ValRange>
					<ValRange   value="1"   paraCNname="侧出">
						<ItemInfo ItemKey="300301" ItemValue="1"  Text="侧"/>
						<ItemInfo ItemKey="300201" ItemValue="0"  Text="出"/>
					</ValRange>
					<ValRange   value="2"   paraCNname="直出">
						<ItemInfo  ItemKey="300301" ItemValue="0" Text="直"/>
						<ItemInfo  ItemKey="300201" ItemValue="0" Text="出"/>
					</ValRange>
					<ValRange   value="3"   paraCNname="直入">
						<ItemInfo  ItemKey="300301"  ItemValue="0" Text="直"/>
						<ItemInfo  ItemKey="300201"  ItemValue="1" Text="入"/>
					</ValRange>
				</parameter>
				<parameter  paravalue=""     paratype="2"  paraIndex="300502"  paraCNname="标志">
				</parameter>
			</Dev> 
		</Step>
	</FunNum>
