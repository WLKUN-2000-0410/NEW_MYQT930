    <Step orderIndex ="2" orderStrName="光路电机">
      <Dev sdkIndex = "1"  DevType="2"  DevName="光路电机"  FunNum="1"  FunName="控制衰减片轮">
        <parameter  paravalue="mode"  paratype="1" paraIndex="200101"  paraCNname="激光器型号">
        </parameter>
        <parameter paravalue="powerindex" paratype="1"  paraIndex="200102"  paraCNname="归零"/>
      </Dev>
    </Step>
    <Step orderIndex ="3" orderStrName="激光器">
      <Dev sdkIndex = "1"  DevType="1"  DevName="激光器"  FunNum="6"  FunName="切换光源">
      </Dev>
    </Step>
    <Step orderIndex ="4" orderStrName="激光器">
      <Dev sdkIndex = "1"  DevType="1"  DevName="激光器"  FunNum="8"  FunName="关闭光源">
        <parameter  paravalue="lasernewvalue"  paratype="1" paraIndex="100801"  paraCNname="激光器型号">
        </parameter>
        <parameter paravalue="powerindex" paratype="1"  paraIndex="100802"  paraCNname="归零"/>
